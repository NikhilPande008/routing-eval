# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv*/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local run artifacts (regenerated by routing:run / routing:frontier)
records.json
*.records.json
frontier.csv
*.frontier.csv

# Documentation
*.md
!/README.md

# Secrets -- never commit (FIREWORKS_API_KEY etc.)
.env
.env.*
!.env.example

# Local-tier ship-set (D44): large binary/model assets staged into the image,
# not source -- docker/entrypoint.sh IS tracked, these are not. Re-fetched by
# whatever staging step populates them (see DECISIONS.md D44), never
# committed; local_assets/ is the raw-download scratch dir behind them.
docker/llama/
docker/models/
local_assets/
*.gguf

# Large binaries that have no business in git history (D39: two of these
# were committed by accident and flagged for cleanup)
*.tar
*.tar.gz
